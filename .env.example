# MongoDB Configuration
MONGO_URI=mongodb://USUARIO:SENHA@HOST:27017/?authSource=admin
MONGO_DATABASE=dwc2json

# IPT DwC-A URLs
IPT_FAUNA_URL=https://ipt.example.org/archive.do?r=fauna
IPT_FLORA_URL=https://ipt.example.org/archive.do?r=flora
IPT_OCCURRENCES_URL=https://ipt.example.org/archive.do?r=ocorrencias

# Optional: occurrence source identifier
OCCURRENCES_SOURCE_ID=occurrences

# Optional: bulk write batch size (default 5000, max 10000)
BULK_BATCH_SIZE=5000

# Optional: logging
LOG_LEVEL=info
LOG_FORMAT=text

# Optional: HTTP download timeout in minutes (default 30)
HTTP_TIMEOUT_MIN=30

# Optional: directory for downloaded DwC-A ZIP cache
# CACHE_DIR=C:\Users\USUARIO\AppData\Local\biodiversidade
